# Kontak WhatsApp — hanya var berprefix VITE_ yang ter-expose ke client (Vite).
# Salin file ini ke .env untuk dev lokal, dan set var yang sama di Vercel
# (Project Settings -> Environment Variables). Opsional: kalau tidak di-set,
# kode pakai nilai fallback yang sama di src/lib/site.ts.

# Nomor untuk link wa.me — DIGIT SAJA (tanpa +, spasi, atau strip)
VITE_WHATSAPP_NUMBER=6287887396493

# Nomor untuk ditampilkan di halaman — format rapi
VITE_WHATSAPP_DISPLAY=+62 878-8739-6493
